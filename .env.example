# Example environment variables for Polymarket agents.
# Copy this file to `.env` and fill in the values.

# API key for accessing Polymarket data (if required).
POLYMARKET_API_KEY=your_api_key_here

# Private key for the trading wallet (DO NOT COMMIT REAL KEYS).
TRADING_WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: WebSocket or HTTP endpoint for the target network.
RPC_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_PROJECT_ID

# Optional: log level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

