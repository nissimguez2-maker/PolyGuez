# === REQUIRED ===
POLYGON_WALLET_PRIVATE_KEY=""       # Polymarket wallet private key
OPENAI_API_KEY=""                   # OpenAI API key (LLM signals)
NEWSAPI_API_KEY=""                  # NewsAPI key (market context)

# === TRADING ===
DASHBOARD_SECRET=""                 # Dashboard auth token
POLYGUEZ_DASHBOARD_PORT=8080        # Local dashboard port (Railway uses $PORT)

# === CLOB ORDER AUTH (required for live mode — maker/taker order signing) ===
# Generate via py_clob_client.ClobClient.create_or_derive_api_creds()
CLOB_API_KEY=""
CLOB_SECRET=""
CLOB_PASS_PHRASE=""

# === SESSION RESET ===
# Set FORCE_RESET=1 to force the Supabase rolling_stats singleton to reset on
# next startup, even if a matching reset_token already exists in the DB.
FORCE_RESET=0

# === OPTIONAL LLM PROVIDERS ===
ANTHROPIC_API_KEY=""                # Claude (alternative to OpenAI)
GROQ_API_KEY=""                     # Groq (alternative to OpenAI)
# Override the model name used per provider (defaults set in PolyGuezConfig)
LLM_MODEL_OPENAI="gpt-4o-mini"
LLM_MODEL_ANTHROPIC="claude-haiku-4-5-20251001"
LLM_MODEL_GROQ="llama3-8b-8192"

# === WEB SEARCH (optional — used by brief_generator.py) ===
TAVILY_API_KEY=""                   # Tavily search API key

# === POLYGON RPC (on-chain balance / Chainlink fallback) ===
# Use Alchemy/QuickNode for production. drpc.org free tier for dev/dry-run.
POLYGON_RPC_URL="https://polygon.drpc.org"

# === DATA FEEDS (defaults shown) ===
BINANCE_WS_URL="wss://stream.binance.com:9443/ws/btcusdt@trade"
COINBASE_WS_URL="wss://ws-feed.exchange.coinbase.com"
POLYMARKET_RTDS_URL="wss://ws-live-data.polymarket.com"

# === SUPABASE (signal, trade, shadow, rolling_stats logging) ===
# MUST be the service_role key — RLS on these tables allows inserts only from
# service_role. If this is ever rotated or replaced with the anon key, the
# bot goes dark silently (see CRIT-01 / OBS-01). The audit-1.5 write-failure
# alerter will fire after 3 consecutive write failures, cooldown-gated 10m.
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
# Optional: direct Postgres DSN for scripts/ops/sb_migrate.py only.
SUPABASE_DB_DSN=""
# Optional: lower the consecutive-failure threshold before Telegram fires.
SUPABASE_FAILURE_ALERT_THRESHOLD=3

SESSION_TAG=V5                       # Bump in Railway Variables to start a new data session

# === TELEGRAM ALERTER (audit 1.5) ===
# Without both of these, alerts degrade to logger.warning only and nobody sees
# an outage. Set them in Railway before considering live mode.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALERT_CHAT_ID=""

# === CHAINLINK ORACLE (Polygon PoS) ===
# drpc.org free tier is OK for dry-run; use Alchemy/QuickNode/Infura before live.
CHAINLINK_RPC_URL="https://polygon.drpc.org"
# Max seconds between a Chainlink buffer sample and eventStartTime before the
# P2B gate skips the cycle. Default 10s. Raise to 60 on Railway if the free
# RPC can't reliably deliver sub-10s samples (LATENCY-TASK-2 / INFRA P0).
MAX_P2B_CHAINLINK_OFFSET_SECONDS=60

# === RAILWAY (scripts/ops/deploy_prod.py + fix_railway_env.py) ===
# Get token: Railway UI → Account → Tokens → Create (scope: project)
# Get project/service UUIDs: Railway UI → service URL, or `railway status --json`
RAILWAY_TOKEN=""
RAILWAY_PROJECT_ID=""
RAILWAY_SERVICE_ID=""

# === HEALTH (optional) ===
# Seconds before /health flips to degraded when loop ages out. Default 120.
HEALTH_MAX_STALE_SECONDS=120
